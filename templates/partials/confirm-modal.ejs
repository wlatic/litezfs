<div id="<%= modalId %>" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60">
  <div class="bg-surface-800 rounded-xl border border-surface-600 p-6 w-full max-w-md mx-4">
    <h3 class="text-lg font-semibold text-white mb-2"><%= title %></h3>
    <p class="text-sm text-gray-400 mb-4"><%= message %></p>
    <% if (typeof confirmText !== 'undefined' && confirmText) { %>
      <p class="text-sm text-gray-400 mb-2">Type <code class="text-red-400"><%= confirmText %></code> to confirm:</p>
      <input type="text" id="<%= modalId %>-input" class="w-full px-3 py-2 rounded-lg bg-surface-700 border border-surface-600 text-white text-sm focus:outline-none focus:ring-2 focus:ring-red-500 mb-4" placeholder="Type to confirm">
    <% } %>
    <div class="flex justify-end gap-3">
      <button onclick="document.getElementById('<%= modalId %>').classList.add('hidden')" class="px-4 py-2 text-sm rounded-lg bg-surface-700 hover:bg-surface-600 text-gray-300 transition-colors">Cancel</button>
      <button id="<%= modalId %>-confirm" class="px-4 py-2 text-sm rounded-lg bg-red-500/20 text-red-400 border border-red-500/30 hover:bg-red-500/30 transition-colors"><%= typeof confirmLabel !== 'undefined' ? confirmLabel : 'Confirm' %></button>
    </div>
  </div>
</div>
