<%- include('../partials/layout-top') %>

<div class="space-y-6">
  <!-- Pool Header -->
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-4">
      <a href="/pools" class="text-gray-400 hover:text-white transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </a>
      <h2 class="text-xl font-semibold text-white"><%= pool.name %></h2>
      <div class="flex items-center gap-2">
        <span class="w-2.5 h-2.5 rounded-full <%= helpers.healthDot(pool.health) %>"></span>
        <span class="<%= helpers.healthColor(pool.health) %> text-sm font-medium"><%= pool.health %></span>
      </div>
    </div>
    <div class="flex gap-2">
      <% if (status && status.scanParsed && status.scanParsed.state === 'in_progress') { %>
        <button class="px-4 py-2 text-sm rounded-lg bg-yellow-500/20 text-yellow-400 border border-yellow-500/30 hover:bg-yellow-500/30 transition-colors" hx-delete="/api/pools/<%= pool.name %>/scrub" hx-swap="none" hx-confirm="Cancel the running scrub?">Cancel Scrub</button>
      <% } else { %>
        <button class="px-4 py-2 text-sm rounded-lg bg-surface-700 hover:bg-surface-600 text-gray-300 transition-colors" hx-post="/api/pools/<%= pool.name %>/scrub" hx-swap="none">Start Scrub</button>
      <% } %>
      <button class="px-4 py-2 text-sm rounded-lg bg-red-500/20 text-red-400 border border-red-500/30 hover:bg-red-500/30 transition-colors" onclick="document.getElementById('export-modal').classList.remove('hidden')">Export Pool</button>
    </div>
  </div>

  <!-- Pool Summary -->
  <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
    <div class="bg-surface-800 rounded-xl border border-surface-600 p-4">
      <div class="text-xs text-gray-500 uppercase tracking-wider">Size</div>
      <div class="text-lg font-semibold text-white mt-1"><%= helpers.formatBytes(pool.size) %></div>
    </div>
    <div class="bg-surface-800 rounded-xl border border-surface-600 p-4">
      <div class="text-xs text-gray-500 uppercase tracking-wider">Used</div>
      <div class="text-lg font-semibold text-white mt-1"><%= helpers.formatBytes(pool.allocated) %></div>
      <div class="text-xs text-gray-500 mt-0.5"><%= pool.capacity %>%</div>
    </div>
    <div class="bg-surface-800 rounded-xl border border-surface-600 p-4">
      <div class="text-xs text-gray-500 uppercase tracking-wider">Free</div>
      <div class="text-lg font-semibold text-white mt-1"><%= helpers.formatBytes(pool.free) %></div>
    </div>
    <div class="bg-surface-800 rounded-xl border border-surface-600 p-4">
      <div class="text-xs text-gray-500 uppercase tracking-wider">Fragmentation</div>
      <div class="text-lg font-semibold text-white mt-1"><%= pool.fragmentation %>%</div>
    </div>
    <div class="bg-surface-800 rounded-xl border border-surface-600 p-4">
      <div class="text-xs text-gray-500 uppercase tracking-wider">Dedup Ratio</div>
      <div class="text-lg font-semibold text-white mt-1"><%= pool.dedup %>x</div>
    </div>
  </div>

  <!-- Capacity Bar -->
  <div class="bg-surface-800 rounded-xl border border-surface-600 p-5">
    <div class="flex justify-between text-sm mb-2">
      <span class="text-gray-400">Capacity</span>
      <span class="text-gray-300"><%= helpers.formatBytes(pool.allocated) %> / <%= helpers.formatBytes(pool.size) %></span>
    </div>
    <div class="h-3 rounded-full bg-surface-600 overflow-hidden">
      <div class="h-full rounded-full <%= helpers.capacityColor(pool.capacity) %> transition-all duration-500" style="width: <%= pool.capacity %>%"></div>
    </div>
    <div class="flex justify-between text-xs text-gray-500 mt-1">
      <span><%= pool.capacity %>% used</span>
      <span><%= helpers.formatBytes(pool.free) %> free</span>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- VDev Tree -->
    <div class="bg-surface-800 rounded-xl border border-surface-600 p-5">
      <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-4">VDev Layout</h3>
      <div id="vdev-tree" hx-get="/partials/vdev-tree/<%= pool.name %>" hx-trigger="every 10s" hx-swap="innerHTML">
        <% if (!vdevs || vdevs.length === 0) { %>
          <p class="text-gray-500 text-sm">No vdev information available</p>
        <% } else { %>
          <% vdevs.forEach(function(vdev) { %>
            <div class="mb-4 last:mb-0">
              <div class="flex items-center gap-2 py-2 px-3 bg-surface-700 rounded-lg">
                <span class="w-2 h-2 rounded-full <%= helpers.healthDot(vdev.health) %>"></span>
                <span class="text-white font-mono text-sm font-medium"><%= vdev.name %></span>
                <span class="text-xs px-2 py-0.5 rounded bg-surface-600 text-gray-400"><%= vdev.type %></span>
                <span class="<%= helpers.healthColor(vdev.health) %> text-xs ml-auto"><%= vdev.health %></span>
              </div>
              <% if (vdev.children.length > 0) { %>
                <div class="ml-6 mt-1 space-y-1 border-l-2 border-surface-600 pl-4">
                  <% vdev.children.forEach(function(disk) { %>
                    <div class="flex items-center gap-2 py-1.5 px-2 rounded hover:bg-surface-700/50">
                      <span class="w-1.5 h-1.5 rounded-full <%= helpers.healthDot(disk.health) %>"></span>
                      <span class="text-gray-300 font-mono text-sm"><%= disk.name %></span>
                      <span class="<%= helpers.healthColor(disk.health) %> text-xs ml-auto"><%= disk.health %></span>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <!-- Scan Status -->
    <div class="bg-surface-800 rounded-xl border border-surface-600 p-5">
      <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-4">Scan Status</h3>
      <% if (!status || !status.scanParsed) { %>
        <p class="text-gray-500 text-sm">No scan information available</p>
      <% } else if (status.scanParsed.type === 'none') { %>
        <p class="text-gray-500 text-sm">No scrubs have been performed on this pool.</p>
      <% } else { %>
        <% var sp = status.scanParsed; %>
        <div class="space-y-3">
          <div class="flex items-center gap-2">
            <span class="text-xs uppercase tracking-wider text-gray-500">Type</span>
            <span class="text-sm text-white"><%= sp.type %></span>
          </div>
          <% if (sp.state === 'in_progress') { %>
            <div class="flex items-center gap-2">
              <span class="text-xs uppercase tracking-wider text-gray-500">Status</span>
              <span class="text-sm text-yellow-400">In Progress</span>
            </div>
            <% if (sp.progress !== undefined) { %>
              <div class="mt-2">
                <div class="flex justify-between text-xs mb-1">
                  <span class="text-gray-400">Progress</span>
                  <span class="text-gray-300"><%= sp.progress %>%</span>
                </div>
                <div class="h-2 rounded-full bg-surface-600 overflow-hidden">
                  <div class="h-full rounded-full bg-blue-500 transition-all" style="width: <%= sp.progress %>%"></div>
                </div>
              </div>
            <% } %>
          <% } else { %>
            <div class="flex items-center gap-2">
              <span class="text-xs uppercase tracking-wider text-gray-500">Status</span>
              <span class="text-sm <%= sp.state === 'completed' ? 'text-green-400' : 'text-gray-400' %>"><%= sp.state %></span>
            </div>
          <% } %>
          <div class="flex items-center gap-2">
            <span class="text-xs uppercase tracking-wider text-gray-500">Repaired</span>
            <span class="text-sm text-white"><%= sp.repaired %></span>
          </div>
          <% if (sp.duration) { %>
            <div class="flex items-center gap-2">
              <span class="text-xs uppercase tracking-wider text-gray-500">Duration</span>
              <span class="text-sm text-white"><%= sp.duration %></span>
            </div>
          <% } %>
          <div class="flex items-center gap-2">
            <span class="text-xs uppercase tracking-wider text-gray-500">Errors</span>
            <span class="text-sm <%= sp.errors > 0 ? 'text-red-400' : 'text-green-400' %>"><%= sp.errors %></span>
          </div>
          <% if (sp.timestamp) { %>
            <div class="flex items-center gap-2">
              <span class="text-xs uppercase tracking-wider text-gray-500">Completed</span>
              <span class="text-sm text-gray-300"><%= sp.timestamp %></span>
            </div>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>

  <!-- I/O Stats -->
  <div class="bg-surface-800 rounded-xl border border-surface-600 p-5">
    <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-4">I/O Statistics</h3>
    <div id="pool-iostat" hx-get="/partials/pool-iostat/<%= pool.name %>" hx-trigger="every 3s" hx-swap="innerHTML">
      <% if (iostat) { %>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div>
            <div class="text-xs text-gray-500 uppercase tracking-wider">Read Ops</div>
            <div class="text-lg font-semibold text-white mt-1"><%= iostat.readOps.toLocaleString() %>/s</div>
          </div>
          <div>
            <div class="text-xs text-gray-500 uppercase tracking-wider">Write Ops</div>
            <div class="text-lg font-semibold text-white mt-1"><%= iostat.writeOps.toLocaleString() %>/s</div>
          </div>
          <div>
            <div class="text-xs text-gray-500 uppercase tracking-wider">Read BW</div>
            <div class="text-lg font-semibold text-white mt-1"><%= helpers.formatBytes(iostat.readBw) %>/s</div>
          </div>
          <div>
            <div class="text-xs text-gray-500 uppercase tracking-wider">Write BW</div>
            <div class="text-lg font-semibold text-white mt-1"><%= helpers.formatBytes(iostat.writeBw) %>/s</div>
          </div>
        </div>
      <% } else { %>
        <p class="text-gray-500 text-sm">No I/O statistics available</p>
      <% } %>
    </div>
  </div>

  <!-- Device Error Counts -->
  <% if (status && status.config && status.config.length > 0) { %>
    <div class="bg-surface-800 rounded-xl border border-surface-600 p-5">
      <h3 class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-4">Device Errors</h3>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-surface-600">
            <th class="text-left px-4 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">Device</th>
            <th class="text-left px-4 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">State</th>
            <th class="text-right px-4 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">Read Errors</th>
            <th class="text-right px-4 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">Write Errors</th>
            <th class="text-right px-4 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">Cksum Errors</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-surface-700">
          <%
            function renderDevices(devices, depth) {
              devices.forEach(function(dev) {
          %>
                <tr class="hover:bg-surface-700/50">
                  <td class="px-4 py-2 text-gray-300 font-mono" style="padding-left: <%= 16 + depth * 20 %>px"><%= dev.name %></td>
                  <td class="px-4 py-2"><span class="<%= helpers.healthColor(dev.state) %>"><%= dev.state %></span></td>
                  <td class="px-4 py-2 text-right <%= dev.read > 0 ? 'text-red-400' : 'text-gray-500' %>"><%= dev.read %></td>
                  <td class="px-4 py-2 text-right <%= dev.write > 0 ? 'text-red-400' : 'text-gray-500' %>"><%= dev.write %></td>
                  <td class="px-4 py-2 text-right <%= dev.cksum > 0 ? 'text-red-400' : 'text-gray-500' %>"><%= dev.cksum %></td>
                </tr>
          <%
                if (dev.children) { renderDevices(dev.children, depth + 1); }
              });
            }
            renderDevices(status.config, 0);
          %>
        </tbody>
      </table>
      <% if (status.errors && status.errors !== 'No known data errors') { %>
        <div class="mt-3 px-4 py-2 rounded bg-red-500/10 border border-red-500/20 text-red-400 text-sm"><%= status.errors %></div>
      <% } else { %>
        <div class="mt-3 px-4 text-xs text-gray-500"><%= status.errors || 'No known data errors' %></div>
      <% } %>
    </div>
  <% } %>

  <!-- Export Modal -->
  <div id="export-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60">
    <div class="bg-surface-800 rounded-xl border border-surface-600 p-6 w-full max-w-md mx-4">
      <h3 class="text-lg font-semibold text-white mb-2">Export Pool</h3>
      <p class="text-sm text-gray-400 mb-4">This will unmount all datasets and make the pool unavailable. Type the pool name to confirm.</p>
      <input type="text" id="export-confirm-input" class="w-full px-3 py-2 rounded-lg bg-surface-700 border border-surface-600 text-white text-sm focus:outline-none focus:ring-2 focus:ring-accent mb-4" placeholder="Type '<%= pool.name %>' to confirm">
      <div class="flex justify-end gap-3">
        <button onclick="document.getElementById('export-modal').classList.add('hidden')" class="px-4 py-2 text-sm rounded-lg bg-surface-700 hover:bg-surface-600 text-gray-300 transition-colors">Cancel</button>
        <button onclick="if(document.getElementById('export-confirm-input').value==='<%= pool.name %>'){fetch('/api/pools/<%= pool.name %>/export',{method:'POST'}).then(function(){window.location.href='/pools'})}" class="px-4 py-2 text-sm rounded-lg bg-red-500/20 text-red-400 border border-red-500/30 hover:bg-red-500/30 transition-colors">Export</button>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/layout-bottom') %>
