<%- include('../partials/layout-top') %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h2 class="text-xl font-semibold text-white">Snapshots</h2>
    <div class="flex items-center gap-3">
      <select id="snapshot-filter" class="px-3 py-1.5 rounded-lg bg-surface-700 border border-surface-600 text-sm text-gray-300 focus:outline-none focus:ring-2 focus:ring-accent"
        onchange="window.location.href='/snapshots' + (this.value ? '?dataset=' + encodeURIComponent(this.value) : '')">
        <option value="">All Datasets</option>
        <% datasets.forEach(function(ds) { %>
          <option value="<%= ds.name %>"<%= selectedDataset === ds.name ? ' selected' : '' %>><%= ds.name %></option>
        <% }) %>
      </select>
      <button onclick="document.getElementById('create-snapshot-modal').classList.remove('hidden')" class="px-4 py-2 text-sm rounded-lg bg-accent hover:bg-accent/80 text-white transition-colors">
        Create Snapshot
      </button>
    </div>
  </div>

  <div class="bg-surface-800 rounded-xl border border-surface-600 overflow-hidden">
    <div id="snapshot-table" hx-get="/partials/snapshot-table<%= selectedDataset ? '?dataset=' + selectedDataset : '' %>" hx-trigger="every 10s" hx-swap="innerHTML">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-surface-600">
            <th class="text-left px-4 py-3 w-8">
              <input type="checkbox" id="select-all-snaps" class="rounded bg-surface-700 border-surface-600" onchange="document.querySelectorAll('.snap-checkbox').forEach(function(cb){cb.checked=this.checked}.bind(this))">
            </th>
            <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Snapshot</th>
            <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Dataset</th>
            <th class="text-right px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Used</th>
            <th class="text-right px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Refer</th>
            <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Created</th>
            <th class="text-center px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-surface-700">
          <% if (snapshots.length === 0) { %>
            <tr><td colspan="7" class="px-4 py-8 text-center text-gray-500">No snapshots found</td></tr>
          <% } %>
          <% snapshots.forEach(function(snap) { %>
            <tr class="hover:bg-surface-700/50 transition-colors">
              <td class="px-4 py-3"><input type="checkbox" class="snap-checkbox rounded bg-surface-700 border-surface-600" value="<%= snap.fullName %>"></td>
              <td class="px-4 py-3 text-white font-mono text-sm"><%= snap.name %></td>
              <td class="px-4 py-3 text-gray-400 font-mono text-sm"><%= snap.dataset %></td>
              <td class="px-4 py-3 text-right text-gray-300"><%= helpers.formatBytes(snap.used) %></td>
              <td class="px-4 py-3 text-right text-gray-300"><%= helpers.formatBytes(snap.refer) %></td>
              <td class="px-4 py-3 text-gray-400">
                <span title="<%= snap.creation %>"><%= helpers.formatDate(snap.creation) %></span>
                <div class="text-xs text-gray-500"><%= helpers.timeAgo(snap.creation) %></div>
              </td>
              <td class="px-4 py-3 text-center">
                <div class="flex items-center justify-center gap-2">
                  <button class="text-xs px-2 py-1 rounded bg-yellow-500/10 text-yellow-400 hover:bg-yellow-500/20 transition-colors" hx-post="/api/snapshots/<%= encodeURIComponent(snap.fullName) %>/rollback" hx-swap="none" hx-confirm="Rollback dataset <%= snap.dataset %> to snapshot <%= snap.name %>? This will revert all changes since the snapshot was taken.">Rollback</button>
                  <button class="text-xs px-2 py-1 rounded bg-red-500/10 text-red-400 hover:bg-red-500/20 transition-colors" hx-delete="/api/snapshots/<%= encodeURIComponent(snap.fullName) %>" hx-swap="none" hx-confirm="Destroy snapshot <%= snap.fullName %>? This cannot be undone." hx-on::after-request="if(event.detail.successful){window.location.reload()}">Destroy</button>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Batch actions -->
  <% if (snapshots.length > 0) { %>
    <div class="flex items-center gap-3">
      <button onclick="destroySelectedSnapshots()" class="px-4 py-2 text-sm rounded-lg bg-red-500/20 text-red-400 border border-red-500/30 hover:bg-red-500/30 transition-colors">Destroy Selected</button>
      <span class="text-xs text-gray-500">Select snapshots above, then click to batch destroy</span>
    </div>
  <% } %>

  <!-- Create Snapshot Modal -->
  <div id="create-snapshot-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60">
    <div class="bg-surface-800 rounded-xl border border-surface-600 p-6 w-full max-w-lg mx-4">
      <h3 class="text-lg font-semibold text-white mb-4">Create Snapshot</h3>
      <form hx-post="/api/snapshots" hx-swap="none" hx-on::after-request="if(event.detail.successful){document.getElementById('create-snapshot-modal').classList.add('hidden');window.location.reload()}">
        <div class="space-y-4">
          <div>
            <label class="block text-sm text-gray-400 mb-1">Dataset</label>
            <select name="dataset" required class="w-full px-3 py-2 rounded-lg bg-surface-700 border border-surface-600 text-white text-sm focus:outline-none focus:ring-2 focus:ring-accent">
              <% datasets.forEach(function(ds) { %>
                <option value="<%= ds.name %>"<%= selectedDataset === ds.name ? ' selected' : '' %>><%= ds.name %></option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Snapshot Name</label>
            <input type="text" name="name" required class="w-full px-3 py-2 rounded-lg bg-surface-700 border border-surface-600 text-white text-sm focus:outline-none focus:ring-2 focus:ring-accent" placeholder="e.g. before-upgrade" value="manual_<%= new Date().toISOString().split('T')[0] %>">
          </div>
          <div class="flex items-center gap-2">
            <input type="checkbox" name="recursive" id="snap-recursive" class="rounded bg-surface-700 border-surface-600">
            <label for="snap-recursive" class="text-sm text-gray-400">Recursive (include child datasets)</label>
          </div>
        </div>
        <div class="flex justify-end gap-3 mt-6">
          <button type="button" onclick="document.getElementById('create-snapshot-modal').classList.add('hidden')" class="px-4 py-2 text-sm rounded-lg bg-surface-700 hover:bg-surface-600 text-gray-300 transition-colors">Cancel</button>
          <button type="submit" class="px-4 py-2 text-sm rounded-lg bg-accent hover:bg-accent/80 text-white transition-colors">Create</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
function destroySelectedSnapshots() {
  var checked = document.querySelectorAll('.snap-checkbox:checked');
  if (checked.length === 0) { alert('No snapshots selected'); return; }
  if (!confirm('Destroy ' + checked.length + ' selected snapshot(s)? This cannot be undone.')) return;
  var promises = Array.from(checked).map(function(cb) {
    return fetch('/api/snapshots/' + encodeURIComponent(cb.value), { method: 'DELETE' });
  });
  Promise.all(promises).then(function() { window.location.reload(); });
}
</script>

<%- include('../partials/layout-bottom') %>
