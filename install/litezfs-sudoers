# /etc/sudoers.d/litezfs
# Allows the litezfs service user to run ZFS and SMART commands without a password
# Covers both /sbin and /usr/sbin paths (varies by distro)
# Install: sudo cp litezfs-sudoers /etc/sudoers.d/litezfs && sudo chmod 440 /etc/sudoers.d/litezfs

litezfs ALL=(ALL) NOPASSWD: /usr/sbin/zfs *
litezfs ALL=(ALL) NOPASSWD: /usr/sbin/zfs
litezfs ALL=(ALL) NOPASSWD: /usr/sbin/zpool *
litezfs ALL=(ALL) NOPASSWD: /usr/sbin/zpool
litezfs ALL=(ALL) NOPASSWD: /sbin/zfs *
litezfs ALL=(ALL) NOPASSWD: /sbin/zfs
litezfs ALL=(ALL) NOPASSWD: /sbin/zpool *
litezfs ALL=(ALL) NOPASSWD: /sbin/zpool
litezfs ALL=(ALL) NOPASSWD: /usr/sbin/smartctl *
litezfs ALL=(ALL) NOPASSWD: /usr/sbin/smartctl
litezfs ALL=(ALL) NOPASSWD: /sbin/smartctl *
litezfs ALL=(ALL) NOPASSWD: /sbin/smartctl
